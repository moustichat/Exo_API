# ============================================================================
# CONFIGURATION SERVEUR
# ============================================================================

# Port sur lequel le serveur Express écoute
PORT=3000

# Environnement (development / production)
NODE_ENV=development

# ============================================================================
# BASE DE DONNÉES
# ============================================================================

# URL de connexion à la base de données SQLite (développement)
# Format: file:./chemin/vers/fichier.db
DATABASE_URL="file:./dev.db"


# ============================================================================
# AUTHENTIFICATION JWT
# ============================================================================

# Clé secrète pour signer les tokens d'accès (ACCESS TOKEN)
# Générer une clé forte: openssl rand -base64 32
JWT_ACCESS_SECRET='your_access_secret_key'

# Clé secrète pour signer les refresh tokens
JWT_REFRESH_SECRET='your_refresh_secret_key'

# Durée de vie du token d'accès (15 minutes recommandé)
JWT_ACCESS_EXPIRES_IN='15m'

# Durée de vie du refresh token (7 jours recommandé)
JWT_REFRESH_EXPIRES_IN='7d'

# ============================================================================
# FRONTEND
# ============================================================================

# URL du frontend (pour les headers CORS et redirections)
# En développement: http://localhost:5173 (port Vite par défaut)
# En production: votre domaine frontend
FRONTEND_URL=http://localhost:5173