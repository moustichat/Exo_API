// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Event {
    id Int @id @default(autoincrement()) 
    title String 
    description String
    date DateTime
    duree String
    lieu String
    ville String
    prix_billet Int
    nombre_total_places Int
    categorie String
    image_couverture Int?
}


// Run `npx prisma migrate dev --name <name>` to create the database and apply the schema changes
// Run `npx prisma generate` to generate the Prisma Client based on this schema